{
  "name": "intranet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:ci": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "NODE_OPTIONS='--require=./tests/unit/register-server-only.cjs' playwright test -c tests/unit/playwright.unit.config.ts",
    "e2e:smoke": "E2E_BASE_URL='http://127.0.0.1:3000' playwright test tests/e2e",
    "e2e:smoke:headed": "E2E_BASE_URL='http://127.0.0.1:3000' playwright test tests/e2e --headed",
    "rc": "npm run lint && npm run typecheck && npm run test:unit && npm run build:ci && npm run e2e:smoke",
    "supabase:provision-trabajador": "node scripts/provision-trabajador-demo.mjs",
    "supabase:reset-users": "node scripts/reset-supabase-users.mjs --yes",
    "storage:cleanup-orphans": "node scripts/cleanup-orphaned-storage.mjs",
    "storage:cleanup-orphans:delete": "node scripts/cleanup-orphaned-storage.mjs --delete",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
